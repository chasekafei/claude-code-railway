# ── Required ──

# Telegram Bot Token (create one via @BotFather)
TG_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Allowed Telegram user IDs, comma-separated, * for everyone
# Find your ID via @userinfobot
TG_ALLOW_FROM=*

# API Key
# DeepSeek users: get it from https://platform.deepseek.com/api_keys
# Anthropic users: get it from https://console.anthropic.com
ANTHROPIC_AUTH_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Personal Access Token (Settings → Developer settings → Personal access tokens)
# Requires repo scope
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── API Configuration (DeepSeek) ──

ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
CLAUDE_CODE_EFFORT_LEVEL=max


# ── Optional ──

# Claude Code edit mode: acceptEdits (confirm before editing) or yolo (auto-edit)
CLAUDE_MODE=acceptEdits

# cc-connect language (zh, en, etc.)
CC_CONNECT_LANGUAGE=zh

# cc-connect project name
CC_CONNECT_PROJECT=workspace

# Git identity (for commits)
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your-email@example.com
